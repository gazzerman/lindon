DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=lindon
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4
APP_URL=https://localhost/lindon/members
MAIL_MODE=log
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME=My Sample Site

# Captcha provider (turnstile or recaptcha). Turnstile is primary.
CAPTCHA_PROVIDER=turnstile
# Local dev: auto-bypass on localhost when empty. Set 1 to always bypass, 0 to force checks.
CAPTCHA_BYPASS=

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Google reCAPTCHA v3 (fallback)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
# Score threshold from 0.0 to 1.0 (higher is stricter)
RECAPTCHA_MIN_SCORE=0.5

